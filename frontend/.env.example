# Copy this file to .env.local for local development.
# For production deployment, set this in your hosting platform's env config
# (or pass as a build arg to the frontend Docker image so Next.js bakes it in).

# Backend API base URL — no trailing slash.
# Local dev:           http://localhost:8000
# Docker compose dev:  http://localhost:8000  (browser hits host, not container)
# Production (example): https://api.bitcoincoding.dev
NEXT_PUBLIC_API_URL=http://localhost:8000
