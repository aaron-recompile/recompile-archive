# Copy to .env before running `docker compose up`.
# .env is gitignored — never commit your real keys.

# === Required ===

# Anthropic API key for the AI endpoints (search, summarize, classify, agent).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === Optional (defaults shown) ===

# Where the browser-side Next.js code fetches the backend.
# Local dev:        http://localhost:8000
# Production:       https://api.your-domain.com  (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000
